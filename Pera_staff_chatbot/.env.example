# ============================================================
# PERA AI — Environment Configuration
# Copy to .env and fill in your values.
# ============================================================

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_BASE_URL=https://api.openai.com/v1
ANSWER_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TRANSCRIBE_MODEL=whisper-1

# ── Base URL (used in PDF reference links) ────────────────
BASE_URL=http://localhost:8000

# ── Authentication ────────────────────────────────────────
# Set AUTH_ENABLED=1 in production. Fails fast if no keys.
AUTH_ENABLED=0
API_KEYS=key1,key2
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256

# ── CORS ──────────────────────────────────────────────────
# Comma-separated origins. Use * only for local dev.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_ENABLED=1
RATE_LIMIT_ASK=30/minute
RATE_LIMIT_TRANSCRIBE=5/minute

# ── Session Backend ───────────────────────────────────────
# "redis" (default, with sqlite fallback) | "sqlite" | "memory"
SESSION_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
SQLITE_SESSION_PATH=data/sessions.db
SESSION_TTL_SECONDS=3600

# ── Audit ─────────────────────────────────────────────────
AUDIT_ENABLED=1
AUDIT_STORE_FULL_TEXT=0

# ── Prompt Versioning ─────────────────────────────────────
PROMPT_VERSION=1.0.0

# ── API Ingestion ───────────────────────────────────────────
# IMPORTANT: Set BOTH to 1 to activate the API data pipeline.
# When enabled, the system will:
#   - Discover YAML configs in assets/apis/
#   - Fetch data from configured .NET APIs (divisions, strength, finance)
#   - Normalize, chunk, and embed API data into the FAISS index
#   - Run background sync every API_SYNC_POLL_SECONDS
# Without this, stored_api and "both" modes return no API data.
API_INGESTION_ENABLED=1
API_SOURCE_DIR=assets/apis
API_SYNC_ENABLED=1
API_SYNC_POLL_SECONDS=300
API_DB_ENABLED=0
API_DB_URL=sqlite:///data/api_ingestion.db
API_SNAPSHOT_DIR=data/api_snapshots
API_SYNC_LOG_DIR=data/api_sync
API_DEFAULT_TIMEOUT_SECONDS=30
API_DEFAULT_RETRY_COUNT=3
API_DEFAULT_RETRY_BACKOFF_SECONDS=2
API_MAX_RESPONSE_BYTES=52428800
API_ALLOW_HTTP=0
API_ALLOW_NON_JSON=0
API_ENABLE_PENDING_REMOVAL_GRACE=1
API_REMOVAL_GRACE_MINUTES=1440
API_BLOCK_EMPTY_SNAPSHOT_REPLACEMENT=1
API_MIN_EXPECTED_RECORDS_DEFAULT=1
API_INDEX_AUTHORITY_DEFAULT=2
API_CHUNK_MAX_CHARS=4500
API_CHUNK_OVERLAP_CHARS=500
API_AUDIT_ENABLED=1

# API source auth tokens (referenced in YAML configs by env var name)
# EMPLOYEES_API_TOKEN=your-token-here
# REGULATIONS_API_KEY=your-key-here

# ── Analytics Database (PostgreSQL) ──────────────────────────
# Master toggle — set to 1 to enable the analytics DB layer
ANALYTICS_DB_ENABLED=0
POSTGRES_URL=postgresql://pera_user:@AhsanFaheemMubeen@localhost:5432/pera_ai
ANALYTICS_DB_POOL_SIZE=5
# Enable writing API records to PostgreSQL during sync
ANALYTICS_WRITE_ENABLED=0
# Days to retain historical analytics data (default: 2 years)
ANALYTICS_RETENTION_DAYS=730
# Auto-run schema migrations on startup
ANALYTICS_AUTO_MIGRATE=1
